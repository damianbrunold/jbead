@inject AppState State
@inject IJSRuntime JS
@inject LocalizationService Loc
@inject HttpClient Http
@implements IDisposable

@* Top bar: file operations + filename only. Everything view-specific lives in
   ViewBar.razor below it. *@
<div class="toolbar">
    <button @onclick="NewFile" title="@(Loc["action.file.new.description"])">@Loc["action.file.new"]</button>
    <div class="open-stepper">
        <label class="upload-btn">
            @Loc["action.file.open"]
            <InputFile OnChange="OnOpen" accept=".jbb,.jbby" style="display:none" />
        </label>
        <div class="open-stepper-popup">
            <div class="open-stepper-header">@Loc["ui.examples"]</div>
            @foreach (var ex in Examples)
            {
                <button type="button" @onclick="() => LoadExample(ex.File)">@Loc[ex.LabelKey]</button>
            }
        </div>
    </div>
    <button @onclick="SaveAs" title="@(Loc["action.file.saveas.description"])">@Loc["action.file.saveas"]</button>
    <button @onclick="OpenPrint" title="@(Loc["action.file.print.description"])">@Loc["action.file.print"]</button>
    <span class="sep"></span>
    <span class="filename">@State.Model.FileName @(State.Model.IsModified ? "*" : "")</span>
    @if (loadError is not null)
    {
        <span class="error">@loadError</span>
    }
    <span class="spacer"></span>
    @foreach (var mode in Enum.GetValues<ViewMode>())
    {
        var m = mode;
        string css = State.ViewMode == m ? "view-mode selected" : "view-mode";
        <button class="@css" @onclick="() => SetViewMode(m)">@ViewModeLabel(m)</button>
    }
</div>

@code {
    private string? loadError;
    private DotNetObjectReference<Toolbar>? selfRef;

    protected override void OnInitialized()
    {
        // Re-render when modified/filename flips so the "*" marker updates,
        // and when the view mode changes so the selected button highlights.
        State.Model.ModelChanged += OnRelevantChange;
        State.Model.PointChanged += _ => OnRelevantChange();
        State.ViewModeChanged += _ => InvokeAsync(StateHasChanged);
        Loc.LanguageChanged += OnLanguageChanged;
        selfRef = DotNetObjectReference.Create(this);
    }

    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    private string ViewModeLabel(ViewMode m) => m switch
    {
        ViewMode.Draft => Loc["draft"],
        ViewMode.Simulation => Loc["simulation"],
        ViewMode.Both => Loc["view.both"],
        _ => m.ToString(),
    };

    private void SetViewMode(ViewMode m) { State.ViewMode = m; StateHasChanged(); }

    public void Dispose()
    {
        State.Model.ModelChanged -= OnRelevantChange;
        Loc.LanguageChanged -= OnLanguageChanged;
        selfRef?.Dispose();
    }

    private bool wasModified;
    private void OnRelevantChange()
    {
        if (State.Model.IsModified == wasModified) return;
        wasModified = State.Model.IsModified;
        StateHasChanged();
    }

    private void NewFile()
    {
        State.Model.Clear();
        State.Model.FileName = "unnamed.jbb";
    }

    private void OpenPrint() => State.PrintDialogOpen = true;

    private async Task SaveAs()
    {
        // JS opens the native picker with both formats; once the user picks a
        // filename, JS calls back into C# with the chosen extension, we serialize
        // with the matching format, and JS writes the bytes.
        string baseName = string.IsNullOrEmpty(State.Model.FileName) ? "pattern" : State.Model.FileName;
        int dot = baseName.LastIndexOf('.');
        if (dot > 0) baseName = baseName.Substring(0, dot);
        await JS.InvokeAsync<bool>("jbeadSaveMerged", baseName, selfRef);
    }

    /// Called from JS once the user has chosen a filename. Returns the base64-encoded
    /// bytes corresponding to the format derived from the selected extension.
    [JSInvokable]
    public string SerializeForExtension(string extensionLower, string fullName)
    {
        byte[] bytes = extensionLower switch
        {
            "jbby" or "yaml" or "yml" => JBeadYamlFileFormat.Save(State.Model),
            _ => JBeadFileFormat.Save(State.Model),
        };
        State.Model.FileName = fullName;
        State.Model.IsModified = false;
        State.Model.IsSaved = true;
        StateHasChanged();
        return Convert.ToBase64String(bytes);
    }

    private record Example(string File, string LabelKey);

    private static readonly Example[] Examples =
    {
        new("hearts.jbb", "ui.example.hearts"),
        new("small_hearts.jbb", "ui.example.small_hearts"),
        new("stripes.jbb", "ui.example.stripes"),
        new("spiral.jbby", "ui.example.spiral"),
        new("stars.jbby", "ui.example.stars"),
        new("green_yellow_diagonal.jbb", "ui.example.green_yellow_diagonal"),
    };

    private async Task LoadExample(string fileName)
    {
        loadError = null;
        try
        {
            byte[] bytes = await Http.GetByteArrayAsync($"samples/{fileName}");
            if (LooksLikeSExpression(bytes) ||
                fileName.EndsWith(".jbb", StringComparison.OrdinalIgnoreCase))
            {
                JBeadFileFormat.Load(State.Model, bytes);
            }
            else
            {
                JBeadYamlFileFormat.Load(State.Model, bytes);
            }
            State.Model.FileName = fileName;
        }
        catch (Exception ex)
        {
            loadError = Loc["ui.loadfailed", [ex.Message]];
        }
    }

    private async Task OnOpen(InputFileChangeEventArgs args)
    {
        loadError = null;
        var file = args.File;
        if (file is null) return;
        await using var stream = file.OpenReadStream(maxAllowedSize: 16 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        byte[] bytes = ms.ToArray();
        try
        {
            if (LooksLikeSExpression(bytes) ||
                file.Name.EndsWith(".jbb", StringComparison.OrdinalIgnoreCase))
            {
                JBeadFileFormat.Load(State.Model, bytes);
            }
            else
            {
                JBeadYamlFileFormat.Load(State.Model, bytes);
            }
            State.Model.FileName = file.Name;
        }
        catch (Exception ex)
        {
            loadError = Loc["ui.loadfailed", [ex.Message]];
        }
    }

    private static bool LooksLikeSExpression(byte[] bytes)
    {
        for (int i = 0; i < bytes.Length; i++)
        {
            byte b = bytes[i];
            if (b == ' ' || b == '\t' || b == '\r' || b == '\n') continue;
            return b == (byte)'(';
        }
        return false;
    }
}
