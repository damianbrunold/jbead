@* Language selector with flag icons sourced from Wikimedia Commons (stable
   public URLs — Wikipedia's canonical image backend). A native <select> would
   force us to pick between text and an image; rolling a small popup lets both
   live side-by-side. Menu opens upward because the picker sits in the footer. *@
@inject LocalizationService Loc
@implements IDisposable

<div class="language-picker @(open ? "open" : "")">
    @if (open)
    {
        @* Transparent full-screen backdrop catches stray clicks — simpler than
           wiring a document-level listener via JS interop. *@
        <div class="lang-backdrop" @onclick="Close"></div>
    }
    <button type="button" class="lang-button" @onclick="ToggleOpen"
            aria-haspopup="listbox" aria-expanded="@(open ? "true" : "false")"
            title="@(Loc["action.pattern.language"])">
        <img class="lang-flag" src="@Loc.FlagUrlFor(Loc.Language)" alt="" width="20" height="14" />
        <span class="lang-name">@CurrentNativeName</span>
        <span class="lang-caret">▾</span>
    </button>
    @if (open)
    {
        <div class="lang-menu" role="listbox">
            @foreach (var lang in Loc.Supported)
            {
                var code = lang.Code;
                var label = lang.NativeName;
                var flag = lang.FlagUrl;
                <button type="button" role="option"
                        class="lang-option @(code == Loc.Language ? "selected" : "")"
                        aria-selected="@(code == Loc.Language ? "true" : "false")"
                        @onclick="() => SelectAsync(code)">
                    <img class="lang-flag" src="@flag" alt="" width="20" height="14" />
                    <span class="lang-name">@label</span>
                </button>
            }
        </div>
    }
</div>

@code {
    private bool open;

    private string CurrentNativeName =>
        Loc.Supported.FirstOrDefault(l => l.Code == Loc.Language)?.NativeName ?? Loc.Language;

    protected override void OnInitialized()
    {
        Loc.LanguageChanged += OnLanguageChanged;
    }

    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    private void ToggleOpen() => open = !open;
    private void Close() => open = false;

    private async Task SelectAsync(string code)
    {
        open = false;
        await Loc.SetLanguageAsync(code);
    }

    public void Dispose()
    {
        Loc.LanguageChanged -= OnLanguageChanged;
    }
}

<style>
    .language-picker { position: relative; display: inline-block; vertical-align: middle; }
    .language-picker .lang-button {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 2px 6px;
        background: white; color: #444;
        border: 1px solid #bbb; border-radius: 2px;
        font: 11px system-ui, sans-serif; cursor: pointer;
    }
    .language-picker .lang-button:hover { background: #f5f5f5; }
    .language-picker .lang-caret { color: #888; font-size: 10px; }
    .language-picker .lang-flag {
        display: inline-block; width: 20px; height: 14px;
        object-fit: cover;
        border: 1px solid #ccc; background: #fafafa;
    }
    /* Menu opens upward because the picker lives in the footer. z-index keeps it
       above the footer and sim-controls. */
    .language-picker .lang-menu {
        position: absolute; bottom: calc(100% + 4px); left: 0;
        background: white; border: 1px solid #bbb; border-radius: 3px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.18);
        z-index: 1001;
        min-width: 150px;
        padding: 2px 0;
    }
    .language-picker .lang-option {
        display: flex; width: 100%;
        align-items: center; gap: 8px;
        padding: 4px 10px;
        background: none; border: none;
        font: 12px system-ui, sans-serif;
        text-align: left; color: #333; cursor: pointer;
    }
    .language-picker .lang-option:hover { background: #eef3ff; }
    .language-picker .lang-option.selected { background: #4c9aff; color: white; }
    .language-picker .lang-backdrop {
        position: fixed; inset: 0;
        z-index: 1000;
        background: transparent;
    }
</style>
